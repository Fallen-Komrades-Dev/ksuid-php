{
    "name": "fallen-komrades-dev/ksuid",
    "description": "K-Sortable Unique Identifier (KSUID) for PHP, ported from ksuid-go and based on tuupola/ksuid",
    "type": "library",
    "license": "MIT",
    "keywords": ["ksuid", "uuid", "identifier", "sortable", "unique"],
    "require": {
        "php": ">=8.1",
        "ext-mbstring": "*"
    },
    "require-dev": {
        "phpunit/phpunit": "^10.5 || ^11.0 || ^12.0",
        "phpunit/php-code-coverage": "^11.0",
        "phpstan/phpstan": "^2.2"
    },
    "suggest": {
        "ext-gmp": "Required to use the GMP-backed XXHash32Gmp / portable arithmetic implementations"
    },
    "autoload": {
        "psr-4": {
            "FallenKomradesDev\\KSUID\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "FallenKomradesDev\\KSUID\\Tests\\": "tests/"
        }
    },
    "scripts": {
        "test": "phpunit",
        "test-coverage": "phpunit --coverage-text --coverage-html=coverage-report",
        "bench": "php benchmark.php"
    },
    "minimum-stability": "stable"
}
